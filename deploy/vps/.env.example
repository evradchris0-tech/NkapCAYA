# ── Copier en `.env` (dans deploy/vps/) et remplir. NE PAS committer le .env. ──

# === MySQL (conteneur) — choisis des mots de passe forts ===
MYSQL_ROOT_PASSWORD=remplace-par-un-mot-de-passe-root-fort
MYSQL_DATABASE=nkapzen
MYSQL_USER=nkapzen
MYSQL_PASSWORD=remplace-par-un-mot-de-passe-fort

# === API ===
# DATABASE_URL pointe vers le service "mysql" du compose (réseau interne Docker).
# Doit utiliser MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE ci-dessus.
DATABASE_URL=mysql://nkapzen:remplace-par-un-mot-de-passe-fort@mysql:3306/nkapzen

# Reprends les MÊMES secrets JWT que la prod actuelle (sinon les sessions existantes sont invalidées) :
JWT_SECRET=colle-le-JWT_SECRET-de-prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=colle-le-JWT_REFRESH_SECRET-de-prod
JWT_REFRESH_EXPIRES_IN=30d

APP_URL=https://api.nkapzen.com
# Origine(s) autorisée(s) pour le web (domaine Vercel) :
ALLOWED_ORIGINS=https://yaca.nkapzen.com
