# ═══════════════════════════════════════════════════════════════════════════════
# CAYA API — Template de configuration (commité dans git)
# Copier en .env pour le développement local
# Pour la production, configurer ces variables dans le dashboard Railway
# ═══════════════════════════════════════════════════════════════════════════════

# ── Base de données MySQL ──────────────────────────────────────────────────────
# Local   : mysql://root:MOT_DE_PASSE@localhost:3306/caya_db
# Railway : fourni automatiquement par le plugin MySQL
DATABASE_URL="mysql://root:@localhost:3306/caya_db"

# ── JWT — OBLIGATOIRE EN PRODUCTION ───────────────────────────────────────────
# Générer : openssl rand -base64 64
JWT_SECRET="CHANGE_ME_STRONG_RANDOM_64_CHARS_MIN"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CHANGE_ME_ANOTHER_STRONG_RANDOM_64_CHARS"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Application ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL="http://localhost:3000"

# ── SMS — Africa's Talking ────────────────────────────────────────────────────
# Sandbox (dev)  : AT_USERNAME=sandbox, laisser AT_API_KEY vide → logs console
# Production     : utiliser les credentials live de votre compte AT
AT_USERNAME="sandbox"
AT_API_KEY=""
AT_SENDER_ID="CAYA"

# ── WhatsApp — Twilio ─────────────────────────────────────────────────────────
# Obtenir sur : https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
