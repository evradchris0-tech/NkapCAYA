# ═══════════════════════════════════════════════════════════════════════════════
# CAYA — Variables d'environnement
# Copier ce fichier en .env (dev local) ou configurer ces variables dans Railway
# Ne jamais committer .env avec de vraies valeurs
# ═══════════════════════════════════════════════════════════════════════════════

# ── Base de données MySQL ──────────────────────────────────────────────────────
# Local dev : mysql://root:PASSWORD@localhost:3306/caya_db
# Railway   : fourni automatiquement par le service MySQL Railway
DATABASE_URL="mysql://root:@localhost:3306/caya_db"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 64
JWT_SECRET="CHANGE_ME_WITH_STRONG_RANDOM_SECRET"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CHANGE_ME_WITH_ANOTHER_STRONG_RANDOM_SECRET"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Application ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development   # production en prod
APP_URL="http://localhost:3000"

# ── SMS — Africa's Talking ────────────────────────────────────────────────────
# Sandbox (dev) : username=sandbox, api_key=obtenu sur https://account.africastalking.com
# Production    : username=omgba (ou votre username live), api_key=clé live AT
AT_USERNAME="sandbox"
AT_API_KEY=""
AT_SENDER_ID="CAYA"

# ── WhatsApp — Twilio ─────────────────────────────────────────────────────────
# Sandbox dev  : +14155238886 (Twilio sandbox)
# Production   : votre numéro WhatsApp Business approuvé
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ── Web (Next.js) — à mettre dans apps/web/.env.local ────────────────────────
# Local  : http://localhost:3000/api/v1
# Prod   : https://VOTRE_API.up.railway.app/api/v1
NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"
