{
  "name": "nkap-caya",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo — Application de gestion de la tontine CAYA",
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "build:api": "prisma generate --schema=database/schema.prisma && npm -w api run build && prisma db push --schema=database/schema.prisma --accept-data-loss && node scripts/init-admin.js",
    "build:web": "pnpm --filter web build",
    "postbuild:web": "node scripts/prepare-web-deploy.js",
    "test": "pnpm --filter api test",
    "test:e2e": "pnpm --filter api test:e2e",
    "lint": "pnpm -r lint",
    "db:migrate": "prisma migrate dev --schema=database/schema.prisma",
    "db:generate": "prisma generate --schema=database/schema.prisma",
    "db:seed": "ts-node --project tsconfig.seed.json database/seeds/index.ts",
    "db:studio": "prisma studio --schema=database/schema.prisma"
  },
  "dependencies": {
    "@nestjs/cli": "^10.3.2",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.3.3",
    "prisma": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@types/express": "^5.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/node": "^20.11.16"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/bcrypt": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
